# Copy to .env for local MySQL / Chroma scripts (API + Streamlit do not require MySQL)
MYSQL_HOSTNAME=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB_NAME=Meta_ML
MYSQL_USER=
MYSQL_PASSWORD=

# Streamlit frontend → FastAPI (local default)
API_BASE_URL=http://localhost:8000

# Optional: override taxonomy graph path
# GRAPH_CACHE_PATH=/absolute/path/to/taxonomy_graph.gpickle
